{
  "apiEndpoint": "https://api.example.com/chatbot/submit",
  "formFields": [
    {
      "id": "userQuery",
      "label": "User Query",
      "type": "textarea",
      "required": true,
      "placeholder": "Enter your question or query..."
    },
    {
      "id": "context",
      "label": "Context",
      "type": "textarea",
      "required": false,
      "placeholder": "Additional context or background information..."
    },
    {
      "id": "tone",
      "label": "Response Tone",
      "type": "select",
      "required": false,
      "options": [
        "Professional",
        "Casual",
        "Friendly",
        "Formal"
      ]
    }
  ],
  "responseFields": [
    {
      "id": "status",
      "label": "Status",
      "type": "text"
    },
    {
      "id": "response",
      "label": "Chatbot Response",
      "type": "text"
    },
    {
      "id": "confidence",
      "label": "Confidence Score",
      "type": "text"
    },
    {
      "id": "timestamp",
      "label": "Timestamp",
      "type": "text"
    }
  ]
} 