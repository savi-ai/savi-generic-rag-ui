{
  "apiEndpoint": "https://api.example.com/customer-support/submit",
  "formFields": [
    {
      "id": "customerIssue",
      "label": "Customer Issue",
      "type": "textarea",
      "required": true,
      "placeholder": "Describe the customer's issue or question..."
    },
    {
      "id": "productCategory",
      "label": "Product Category",
      "type": "select",
      "required": true,
      "options": [
        "Software",
        "Hardware",
        "Service",
        "Billing",
        "Account",
        "Technical"
      ]
    },
    {
      "id": "priority",
      "label": "Priority Level",
      "type": "select",
      "required": true,
      "options": [
        "Low",
        "Medium",
        "High",
        "Critical"
      ]
    },
    {
      "id": "customerTier",
      "label": "Customer Tier",
      "type": "select",
      "required": false,
      "options": [
        "Basic",
        "Premium",
        "Enterprise",
        "VIP"
      ]
    },
    {
      "id": "previousAttempts",
      "label": "Previous Resolution Attempts",
      "type": "textarea",
      "required": false,
      "placeholder": "Describe any previous attempts to resolve this issue..."
    }
  ],
  "responseFields": [
    {
      "id": "status",
      "label": "Status",
      "type": "text"
    },
    {
      "id": "solution",
      "label": "Proposed Solution",
      "type": "text"
    },
    {
      "id": "escalationNeeded",
      "label": "Escalation Required",
      "type": "text"
    },
    {
      "id": "estimatedResolutionTime",
      "label": "Estimated Resolution Time",
      "type": "text"
    },
    {
      "id": "timestamp",
      "label": "Timestamp",
      "type": "text"
    }
  ]
} 