{
  "apiEndpoint": "https://api.example.com/document-analysis/submit",
  "formFields": [
    {
      "id": "documentType",
      "label": "Document Type",
      "type": "select",
      "required": true,
      "options": [
        "Contract",
        "Report",
        "Research Paper",
        "Legal Document",
        "Technical Manual"
      ]
    },
    {
      "id": "analysisType",
      "label": "Analysis Type",
      "type": "select",
      "required": true,
      "options": [
        "Summary",
        "Key Points Extraction",
        "Risk Assessment",
        "Compliance Check",
        "Technical Review"
      ]
    },
    {
      "id": "specificQuestions",
      "label": "Specific Questions",
      "type": "textarea",
      "required": false,
      "placeholder": "Any specific questions you want answered about the document..."
    },
    {
      "id": "outputFormat",
      "label": "Output Format",
      "type": "select",
      "required": false,
      "options": [
        "Bullet Points",
        "Paragraph",
        "Table",
        "JSON"
      ]
    }
  ],
  "responseFields": [
    {
      "id": "status",
      "label": "Status",
      "type": "text"
    },
    {
      "id": "summary",
      "label": "Document Summary",
      "type": "text"
    },
    {
      "id": "keyFindings",
      "label": "Key Findings",
      "type": "text"
    },
    {
      "id": "recommendations",
      "label": "Recommendations",
      "type": "text"
    },
    {
      "id": "timestamp",
      "label": "Timestamp",
      "type": "text"
    }
  ]
} 